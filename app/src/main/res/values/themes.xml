<resources>
    <style name="Base.Theme.SmartbizHelper" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary & Secondary -->
        <item name="colorPrimary">@color/teal_light</item>
        <item name="colorPrimaryVariant">@color/cyan_dark</item>
        <item name="colorSecondary">@color/teal_medium</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/off_white</item>
        <item name="colorSurface">@color/white</item>

        <!-- Text & Icons -->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnBackground">@color/green_dark</item>
        <item name="colorOnSurface">@color/green_dark</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.SmartbizHelper.BottomNavigationView</item>
    </style>

    <style name="Widget.SmartbizHelper.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/teal_light</item>
        <item name="itemIconTint">@color/white</item>
        <item name="itemTextColor">@color/white</item>
        <item name="itemRippleColor">@color/bottom_nav_focus</item>
    </style>

    <style name="Theme.SmartbizHelper" parent="Base.Theme.SmartbizHelper" />
</resources>
